<core:FragmentDefinition 
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
>

    <VBox id="idChangeProductFragmentVBox" class="sapUiSmallMargin">

        <form:SimpleForm id="idEditSimpleForm" editable="true">
            <form:title>
                <core:Title id="idEditProductInformationTitle" text="{i18n>EditProductInformation}"/>
            </form:title>

            <form:content>

                <Label id="idProductIDFragmentEditLabel" text="{i18n>productId}" required="true"/>
                <Input id="idProductFragmentEditInput" 
                    value = "{
                        path: 'form>/product', 
                        type: 'sap.ui.model.type.String',
                        constraints: { 
                            minLength:7,
                            maxLength: 7
                        }
                    }"
                />

                <Label id="idProductNameFragmentEditLabel" text="{i18n>productName}" required="true"/>
                <Input id="idProductNameFragmentEditInput" 
                    value = "{
                        path: 'form>/productName', 
                        type: 'sap.ui.model.type.String',
                        constraints: { 
                            minLength:4,
                            maxLength: 40
                        }
                    }"
                />

                <Label id="idDescriptionFragmentEditLabel" text="{i18n>description}"/>
                <TextArea id="idDescriptionFragmentEditTextArea" 
                    value = "{
                        path: 'form>/description', 
                        type: 'sap.ui.model.type.String',
                        constraints: { 
                            minLength:1
                        }
                    }"
                />

                <Label id="idSupplierFragmentEditLabel" text="{i18n>supplier}" required="true"/>
                <ComboBox id="idSuppliersSetFragmentEditComboBox" items="{/SuppliersSet}" 
                    selectedKey = "{
                        path: 'form>/supplier_ID', 
                        type: 'sap.ui.model.type.String',
                        constraints: { 
                            minLength:1
                        }
                    }"
                >
                    <core:Item id="idSupplierNameFragmentEditItem" key="{ID}" text="{supplierName}"/>
                </ComboBox>

                <Label id="idCategoryFragmentEditLabel" text="{i18n>category}" required="true"/>
                <ComboBox id="idVhCategoriesSetFragmentEditComboBox" items="{/VH_CategoriesSet}"
                    selectedKey = "{
                        path: 'form>/category_ID', 
                        type: 'sap.ui.model.type.String',
                        constraints: { 
                            minLength:1
                        }
                    }"
                >
                    <core:Item id="idCategoryNameFragmentEditItem" key="{ID}" text="{category}"/>
                </ComboBox>

                <Label id="idSubCategoryFragmentEditLabel" text="{i18n>subCategory}" required="true"/>
                <ComboBox id="idVhSubCategoriesSetFragmentEditComboBox" items="{/VH_SubCategoriesSet}"
                    selectedKey = "{
                        path: 'form>/subCategory_ID', 
                        type: 'sap.ui.model.type.String',
                        constraints: { 
                            minLength:1
                        }
                    }"
                >
                    <core:Item id="idSubCategoryNameFragmentEditItem" key="{ID}" text="{subCategory}"/>
                </ComboBox>

                <Label id="idStockFragmentEditLabel" text="{i18n>stock}" required="true"/>
                <ComboBox id="idVhStockFragmentEditComboBox" items="{/VH_Stock}"
                    selectedKey = "{
                        path: 'form>/stock_code', 
                        type: 'sap.ui.model.type.String',
                        constraints: { 
                            minLength: 1
                        }
                    }"
                >
                    <core:Item id="idNameFragmentEditItem" key="{code}" text="{name}"/>
                </ComboBox>

                <Label id="idPriceFragmentEditLabel" text="{i18n>price}"/>
                <Input id="idPriceFragmentEditInput"
                    value = "{
                        path: 'form>/price', 
                        type: 'sap.ui.model.type.Float',
                        constraints: { 
                            minimum: 1
                        }
                    }"
                    description="{form>/currency}"
                />

                <Label id="idRatingFragmentEditLabel" text="{i18n>rating}"/>
                <RatingIndicator id="idRatingFragmentEditRatingIndicator"
                    editable="{= ${view>/actionButtonsInfo/midColumn/isEditMode} }"
                    value = "{
                        path: 'form>/rating', 
                        type: 'sap.ui.model.type.Integer',
                        constraints: { 
                            minimum:1
                        }
                    }"
                />
                
            </form:content>

        </form:SimpleForm>

    </VBox>

</core:FragmentDefinition>