<mvc:View controllerName="santos.sapui5productsfe.controller.Master"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:filterbar="sap.ui.comp.filterbar">

    <f:DynamicPage id="idDynamicPage">

        <f:title>
            <f:DynamicPageTitle id="idDynamicPageTitle" backgroundDesign="Solid">
                <f:heading>
                    <Title id="idProductsTitle" text="{i18n>appTitle}" wrapping="true"/>
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader id="idDynamicPageHeader">
                <filterbar:FilterBar id="idFilterBar" 
                    search="onFilterBarSearch" 
                    showClearOnFB="true"
                    clear="onFilterBarClear"
                >
                    <filterbar:filterGroupItems>

                        <filterbar:FilterGroupItem id="idProductNameFilterGroupItem"
                            groupName="productsFilters" 
                            name="productName"
                            label="{i18n>productName}"
                            visibleInFilterBar="true"
                        >
                            <filterbar:control>
                                <Input id="idProductInput"/>
                            </filterbar:control>
                        </filterbar:FilterGroupItem>

                        <filterbar:FilterGroupItem id="idSupplierNameFilterGroupItem"
                            groupName="productsFilters" 
                            name="supplier_ID"
                            label="{i18n>supplier}"
                            visibleInFilterBar="true"
                        >
                            <filterbar:control>
                                <ComboBox id="idSuppliersSetComboBox" items="{/SuppliersSet}">
                                    <core:ListItem id="idSupplierNameListItem" key="{ID}" text="{supplierName}"/>
                                </ComboBox>
                            </filterbar:control>
                        </filterbar:FilterGroupItem>

                        <filterbar:FilterGroupItem id="idCategoryFilterGroupItem"
                            groupName="productsFilters" 
                            name="category_ID"
                            label="{i18n>category}"
                            visibleInFilterBar="true"
                        >
                            <filterbar:control>
                                <ComboBox id="idVhCategoriesSetComboBox" items="{/VH_CategoriesSet}">
                                    <core:ListItem id="idCategoryNameListItem" key="{ID}" text="{category}"/>
                                </ComboBox>
                            </filterbar:control>
                        </filterbar:FilterGroupItem>

                        <filterbar:FilterGroupItem id="idStockFilterGroupItem"
                            groupName="productsFilters" 
                            name="stock_code"
                            label="{i18n>stock}"
                            visibleInFilterBar="true"
                        >
                            <filterbar:control>
                                <ComboBox id="idVhStockStockComboBox" items="{/VH_Stock}">
                                    <core:ListItem id="idNameStockListItem" key="{code}" text="{name}"/>
                                </ComboBox>
                            </filterbar:control>
                        </filterbar:FilterGroupItem>

                        <filterbar:FilterGroupItem id="idRatingFilterGroupItem"
                            groupName="productsFilters"
                            name="rating"
                            label="{i18n>rating}"
                            visibleInFilterBar="true"
                        >
                            <filterbar:control>
                                <RatingIndicator id="idRatingIndicator"/>
                            </filterbar:control>
                        </filterbar:FilterGroupItem>

                        <filterbar:FilterGroupItem id="idPriceFilterGroupItem"
                            groupName="productsFilters"
                            name="price"
                            label="{i18n>price}"
                            visibleInFilterBar="true"
                        >
                            <filterbar:control>
                                <RangeSlider id="idPriceRangeSlider" showAdvancedTooltip="true"/>
                            </filterbar:control>
                        </filterbar:FilterGroupItem>

                    </filterbar:filterGroupItems>
                </filterbar:FilterBar>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <Table id="idProductsSetTable"
                items="{/ProductsSet}" 
                growing="true" 
                growingScrollToLoad="true" 
                mode="SingleSelectMaster"
                itemPress="navToDetails"
            >

                <headerToolbar>
                    <Toolbar id="idCountProductsToolbar">
                        <Title id="idCountProductsTitle" text="{i18n>appTitle} ({/ProductsSet/$count})"/>
                        <ToolbarSpacer id="idToolbarSpacer"/>
                        <Button id="idCreateButton" 
                            text="{i18n>create}"
                            tooltip="{i18n>create}"
                            type="Emphasized"
                            press="onCreateButtonPress"
                        />
                    </Toolbar>
                </headerToolbar>

                <columns>
                    <Column id="idProductColumn" demandPopin="true" minScreenWidth="Small">
                        <Label id="idProductIDLabel" text="{i18n>productId}"/>
                    </Column>

                    <Column id="idProductNameColumn" demandPopin="true" minScreenWidth="Small">
                        <Label id="idProductNameLabel" text="{i18n>productName}"/>
                    </Column>

                    <Column id="idSupplierColumn" demandPopin="true" minScreenWidth="Small">
                        <Label id="idSupplierLabel" text="{i18n>supplier}"/>
                    </Column>

                    <Column id="idCategoryColumn" demandPopin="false" minScreenWidth="Small">
                        <Label id="idCategoryLabel" text="{i18n>category}"/>
                    </Column>

                    <Column id="idStockColumn" demandPopin="true" minScreenWidth="Small">
                        <Label id="idStockLabel" text="{i18n>stock}"/>
                    </Column>

                    <Column id="idRatingColumn" demandPopin="false" minScreenWidth="Small">
                        <Label id="idRatingLabel" text="{i18n>rating}"/>
                    </Column>

                    <Column id="idPriceColumn" demandPopin="true" minScreenWidth="Small">
                        <Label id="idPriceLabel" text="{i18n>price}"/>
                    </Column>
                </columns>

                <items>
                    <ColumnListItem id="idColumnListItem" type="Navigation">
                        <cells>
                            <ObjectIdentifier id="idProductObjectIdentifier" text="{product}"/>

                            <Text id="idProductNameText" text="{productName}"/>
                            <Text id="idSupplierNameText" text="{supplier/supplierName}"/>
                            <Text id="idCategoryText" text="{category/category}"/>
                            <ObjectStatus id="idStockCodeObjectStatus" text="{stock_code}"
                                state="{=
                                    ${stock_code} === 'Available'        ? 'Success' :
                                    ${stock_code} === 'LowAvailability'  ? 'Warning' :
                                    ${stock_code} === 'NotAvailable'     ? 'Error'   : 'None'
                                }"
                            />
                            <RatingIndicator id="idRatingRatingIndicator" 
                                value="{rating}" 
                                iconSize="1.25rem" 
                                editable="false"
                                class="sapUiMediumMarginBegin"
                            />
                            <ObjectNumber id="idPriceObjectNumber" 
                                number="{ 
                                    parts: ['price', 'currency'], 
                                    type: 'sap.ui.model.type.Currency', 
                                    formatOptions: {
                                        showMeasure: false
                                    } 
                                }"
                                unit="{currency}"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </f:content>

        <f:footer>
        </f:footer>

    </f:DynamicPage>

</mvc:View>