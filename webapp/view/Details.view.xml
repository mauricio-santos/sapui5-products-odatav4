<mvc:View controllerName="santos.sapui5productsfe.controller.Details"
	xmlns="sap.m"
	xmlns:uxap="sap.uxap"
	xmlns:mvc="sap.ui.core.mvc"
>

    <uxap:ObjectPageLayout id="idObjectPageLayout">

	    <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle id="idObjectPageDynamicHeaderTitle">
                <uxap:expandedHeading>
                    <FlexBox id="idExpandedHeadingFlexBox" fitContainer="true" alignItems="Center">
                        <Title id="idProductExpandedHeadingTitle" text="{product}"/>
                    </FlexBox>
                </uxap:expandedHeading>

                <uxap:snappedHeading>
                    <FlexBox id="idSnappedHeadingFlexBox" fitContainer="true" alignItems="Center">
                        <Title id="idProductSnappedHeadingTitle" text="{product}"/>
                    </FlexBox>
                </uxap:snappedHeading>

                <uxap:expandedContent>
                    <Title id="idProductNameExpandedContentTitle" text="{productName}"/>
                </uxap:expandedContent>

                <uxap:snappedContent>
                    <Title id="idProductNameSnappedContentTitle" text="{productName}"/>
                </uxap:snappedContent>

                <uxap:actions>

                    <Button id="idDeleteButton" 
                        icon="sap-icon://delete" 
                        text="{i18n>delete}" 
                        type="Reject"
                        visible="{= !${view>/actionButtonsInfo/midColumn/isEditMode} ? true : false}"
                        press="onButtonDeletePress"
                    />

                    <Button id="idSaveButton" 
                        icon="sap-icon://save" 
                        text="{i18n>save}" 
                        type="Accept"
                        visible="{= ${view>/actionButtonsInfo/midColumn/isEditMode} ? true : false}"
                        press="onButtonSavePress"
                    />

                    <Button id="idCancelButton"
                        icon="sap-icon://cancel" 
                        text="{i18n>cancel}" 
                        type="Attention"
                        visible="{= ${view>/actionButtonsInfo/midColumn/isEditMode} ? true : false}"
                        press="onButtonCancelPress"
                    />

                    <Button id="idEditButton" 
                        icon="sap-icon://edit" 
                        text="{i18n>edit}" 
                        type="Emphasized"
                        visible="{= !${view>/actionButtonsInfo/midColumn/isEditMode} ? true : false}"
                        press="onButtonEditPress"
                    />

                    <Button id="idFullScreenButton" 
                        icon="{= !${view>/actionButtonsInfo/midColumn/fullScreen} ? 'sap-icon://full-screen' : 'sap-icon://exit-full-screen'}"
                        press="onButtonToggleFullScreenPress"
                    />

                    <Button  id="idCloseViewDetailsButton"
                        icon="sap-icon://decline"
                        press="onButtonCloseViewDetailsPress"
                    />

                </uxap:actions>
            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>

        <uxap:sections>
            <uxap:ObjectPageSection id="idObjectPageSection" title="{i18n>productInformation}">
                <uxap:ObjectPageSubSection id="idObjectPageSubSection">
                    <uxap:blocks>
                        <FlexBox id="idformContainerFlexBox" direction="Column"/>
                    </uxap:blocks>
                </uxap:ObjectPageSubSection>
            </uxap:ObjectPageSection>
        </uxap:sections>

    </uxap:ObjectPageLayout>

</mvc:View>